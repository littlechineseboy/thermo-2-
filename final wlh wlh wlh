import numpy as np
import matplotlib.pyplot as plt
import time


# 1. BUILD SYSTEM

def build_system(N, T=100):

    A = np.zeros((N*N, N*N))
    b = np.zeros(N*N)

    for i in range(N):
        for j in range(N):

            k = i*N + j

            # ---boundary---
            if i == 0 or i == N-1 or j == 0 or j == N-1:
                A[k, k] = 1
                b[k] = T

            # ---interior---
            else:
                A[k, k] = -4
                A[k, k-1] = 1
                A[k, k+1] = 1
                A[k, k-N] = 1
                A[k, k+N] = 1

    return A, b

# 2. GAUSS-SEIDEL

def gauss_seidel(A, b, tol=1e-6, max_iter=2000):

    n = len(b)
    x = np.zeros(n)
    residuals = []

    for it in range(max_iter):

        for i in range(n):

            s1 = np.dot(A[i, :i], x[:i])      # updated values
            s2 = np.dot(A[i, i+1:], x[i+1:])  # old values

            x[i] = (b[i] - s1 - s2) / A[i, i]

        r = np.linalg.norm(A @ x - b)
        residuals.append(r)

        if r < tol:
            print(f"  Convergence en {it+1} itérations  (résidu = {r:.2e})")
            break

    return x, residuals

# 3. DIRECT SOLVER

def direct_solver(A, b):
    return np.linalg.solve(A, b)

# 4. EXPERIMENT

def experiment(N, T):

    print(f"\n  N={N}, T_bord={T}°")

    A, b = build_system(N, T)

    t0 = time.time()
    x_direct = direct_solver(A, b)
    t_direct = time.time() - t0

    t0 = time.time()
    x_gs, res = gauss_seidel(A, b)
    t_gs = time.time() - t0

    error   = np.max(np.abs(x_direct - x_gs))
    rel_err = error / (np.abs(x_direct).max() + 1e-12)

    print(f"  Erreur max      = {error:.2e}")
    print(f"  Erreur relative = {rel_err:.2e}")
    print(f"  Temps direct    = {t_direct*1000:.2f} ms  |  Temps GS = {t_gs*1000:.2f} ms")
    print(f"  Itérations GS   = {len(res)}")

    return x_direct, x_gs, res, error, rel_err, t_direct, t_gs


